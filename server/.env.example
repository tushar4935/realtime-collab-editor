# MongoDB Atlas connection string.
# Atlas dashboard -> Database -> Connect -> Drivers -> copy the string,
# then replace <db_password> with your database user's password.
# Add a database name ("collab-editor") after the host, before the "?".
MONGODB_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@YOUR_CLUSTER.mongodb.net/collab-editor?retryWrites=true&w=majority

# Port for the Express API. Local dev uses 4000. On Render this is provided
# automatically — do NOT set it there; the code already reads process.env.PORT.
PORT=4000

# Secret used to sign JWTs. Any long random string. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-string

# OPTIONAL. In production, set this to your deployed frontend URL (e.g.
# https://your-app.vercel.app) to lock the API to that one origin. Leave it
# unset for local development (any origin is allowed). No trailing slash.
# CLIENT_ORIGIN=https://your-app.vercel.app

