# The client reads these at BUILD time (Vite inlines VITE_* vars), so set them
# in your host's build environment (Vercel/Netlify), not at runtime.

# Base URL of the Express API.
#   Local dev: defaults to http://localhost:4000 if unset, so you can skip it.
#   Production: your Render backend URL, e.g. https://collab-editor.onrender.com
VITE_API_URL=http://localhost:4000

# Yjs websocket sync endpoint (same backend service, /collab path).
#   Local dev: defaults to ws://localhost:4000/collab if unset.
#   Production: wss:// (secure) at the same Render host, e.g.
#               wss://collab-editor.onrender.com/collab
VITE_WS_URL=ws://localhost:4000/collab
